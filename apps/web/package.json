{
  "name": "@opencalendly/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ../../scripts/ensure-dev-port.mjs 3000 web-dev-port && node -e \"require('node:fs').rmSync('.next', { recursive: true, force: true })\" && next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "pages:build": "node ../../scripts/build-pages-output.mjs"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.1",
    "@opencalendly/shared": "0.1.0",
    "cobe": "^0.6.5",
    "next": "^15.4.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4"
  }
}
