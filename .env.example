# Shared
# Neon direct connection string (.neon.tech).
DATABASE_URL=
# Optional but required for `npm run db:reset:local`.
# Must point to a disposable Neon database/branch used only for destructive local reset flows.
RESET_DATABASE_URL=
# Generate using: openssl rand -hex 32
SESSION_SECRET=
# Generate using: openssl rand -hex 32 (recommended stable key for telemetry hashing)
TELEMETRY_HMAC_KEY=
APP_BASE_URL=
# Use http://localhost:8787 for cookie-based local API auth. Avoid 127.0.0.1 here.
API_BASE_URL=
NEXT_PUBLIC_API_BASE_URL=

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
HYPERDRIVE_ID=
CLOUDFLARE_PAGES_PROJECT=
CLOUDFLARE_PAGES_PRODUCTION_BRANCH=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Auth (Clerk)
CLERK_ALLOWED_AUDIENCES=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Local development
# Local development only: enables POST /v0/dev/auth/bootstrap for Playwright/local browser auth bootstrapping.
# Valid values: true to enable, false or empty to disable.
# SECURITY WARNING: never enable this in production or shared environments.
ENABLE_DEV_AUTH_BOOTSTRAP=

# Google Calendar OAuth (Feature 6)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Calendar OAuth (Feature 7)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Demo Credits Pool (Feature 3)
DEMO_DAILY_ACCOUNT_LIMIT=
DEMO_DAILY_CREDIT_LIMIT=
DEMO_CREDIT_BYPASS_EMAILS=
